{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cohort:shared",
  "title": "Cohort shared frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "kind",
    "scope",
    "description",
    "targets"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Kebab slug; must equal the filename stem."
    },
    "kind": {
      "type": "string",
      "enum": [
        "agent",
        "skill",
        "command",
        "hook",
        "memory",
        "context"
      ]
    },
    "scope": {
      "type": "string",
      "enum": [
        "global",
        "project"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "claude",
          "codex",
          "cursor",
          "all"
        ]
      }
    },
    "version": {
      "type": "string",
      "default": "0.1.0",
      "description": "Free-form string in v0.1; not format-validated. Defaults to 0.1.0."
    },
    "owner": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "overrides": {
      "type": "boolean",
      "description": "My-layer only: deliberately overrides the office artifact of the same (kind, name). Set by `cohort personalize`."
    },
    "office_sha256": {
      "type": "string",
      "description": "Content hash of the office artifact at personalize time (stale-override detection)."
    }
  }
}
