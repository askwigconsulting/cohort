{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cohort:agent",
  "title": "Cohort agent frontmatter (composed with shared)",
  "type": "object",
  "required": ["department"],
  "properties": {
    "department": {
      "type": "string"
    },
    "topology": {
      "type": "string",
      "enum": ["specialist", "generalist"],
      "default": "specialist"
    },
    "advisory": {
      "type": "boolean",
      "default": true,
      "description": "v1 safety invariant: must be true."
    },
    "tools": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "model": {
      "type": "string",
      "enum": ["fast", "default", "top"],
      "default": "default",
      "description": "Abstract cost/latency tier — never a concrete model ID. Each renderer maps it to that IDE's model names at compile time."
    }
  }
}
